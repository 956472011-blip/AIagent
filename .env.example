# Application
APP_NAME=rag-assistant
APP_ENV=dev
DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# LLM (M1+ 启用)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Qdrant (M2+ 启用)
# 你云服务器上 Qdrant 的地址,M2 时改成实际值
QDRANT_URL=http://your-cloud-server:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=docs
